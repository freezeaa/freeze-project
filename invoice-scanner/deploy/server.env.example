# 复制为服务器实际环境变量文件，例如：/home/ubuntu/freeze-project/invoice-scanner/deploy/server.env

APP_HOST=127.0.0.1
APP_PORT=5000
APP_DEBUG=false

# 导出文件与日志路径可按服务器目录调整
EXPORT_DIR=/home/ubuntu/freeze-project/invoice-scanner/static/exports
LOG_PATH=/home/ubuntu/freeze-project/invoice-scanner/scanner.log

# Gunicorn 参数
GUNICORN_WORKERS=2
GUNICORN_THREADS=4
GUNICORN_TIMEOUT=120
